      </div>
    </section>
  </main>
</BaseLayout>

<style>
  @font-face {
    font-family: 'Candy Beans';
    src: url('/Candy Beans.otf') format('opentype');
    font-weight: normal;
    font-style: normal;
  }

  .stage {
    min-block-size: 100vh;
    min-block-size: 100dvb;
    display: grid;
    place-items: center;
    align-content: center;
    padding: 2rem 1.5rem 3rem;
    background: linear-gradient(to bottom, #aeffe4, #005f40);
  }

  .stage :global(*),
  .stage :global(*::before),
  .stage :global(*::after) {
    box-sizing: border-box;
  }

  .callout {
    inline-size: min(38rem, 100%);
    padding: 2.5rem 2rem 2rem;
    color: #fff;
    font-family: 'Candy Beans', sans-serif;
    text-align: center;
    text-transform: uppercase;
    background:
      linear-gradient(180deg, rgb(5 88 58 / 0.78), rgb(3 56 38 / 0.92)),
      radial-gradient(circle at top, rgb(174 255 228 / 0.24), transparent 55%);
    border: 4px solid rgb(174 255 228 / 0.72);
    border-radius: 1.5rem;
    box-shadow:
      0 1rem 2.5rem rgb(0 30 20 / 0.28),
      inset 0 1px 0 rgb(255 255 255 / 0.35);
  }

  .callout > * {
    position: relative;
    z-index: 1;
  }

  .callout__brand {
    margin: 0 0 0.25rem;
    font-size: clamp(2.2rem, 4.2vw, 3.4rem);
    line-height: 1;
    letter-spacing: 0.05em;
    color: #83ff00;
    text-shadow:
      0 2px 0 rgb(0 72 38 / 0.82),
      0 0 0.45rem rgb(70 255 152 / 0.7),
      0 0 1rem rgb(70 255 152 / 0.45);
  }

  .callout__sub {
    margin: 0 0 2rem;
    font-size: clamp(1rem, 1.6vw, 1.3rem);
    line-height: 1.1;
    letter-spacing: 0.08em;
    color: #aeffe4;
    text-shadow:
      0 1px 0 rgb(0 72 38 / 0.7),
      0 0 0.4rem rgb(174 255 228 / 0.4);
  }

  .years {
    display: grid;
    gap: 1rem;
  }

  .year {
    display: grid;
    gap: 0.25rem;
    padding: 1rem 1.5rem 0.9rem;
    color: #fff;
    text-decoration: none;
    border-radius: 1rem;
    border: 3px solid rgb(174 255 228 / 0.55);
    transition:
      transform 80ms ease,
      border-color 80ms ease,
      box-shadow 80ms ease;
  }

  .year:hover,
  .year:focus-visible {
    transform: scale(1.03);
    border-color: #d7fff2;
    box-shadow: 0 0.85rem 1.5rem rgb(0 0 0 / 0.22);
    outline: none;
  }

  .year__label {
    font-size: clamp(2rem, 3.2vw, 2.8rem);
    line-height: 1;
    letter-spacing: 0.06em;
    text-shadow: 0 2px 0 rgb(0 72 38 / 0.7);
  }

  .year__status {
    font-size: clamp(0.85rem, 1.3vw, 1.1rem);
    line-height: 1;
    letter-spacing: 0.1em;
    color: #ffd652;
    text-shadow: 0 1px 0 rgb(0 72 38 / 0.6);
  }

  .year--2026 {
    background: linear-gradient(180deg, rgb(15 138 97 / 0.7), rgb(0 95 64 / 0.7));
  }

  .year--2025 {
    background: linear-gradient(180deg, rgb(0 95 64 / 0.55), rgb(0 72 38 / 0.55));
  }

  .social {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.8rem;
    margin-top: 1.5rem;
  }

  .socialLink {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: 4em;
    block-size: 4em;
    padding: 0;
    color: #fff;
    text-decoration: none;
    background: linear-gradient(180deg, #0f8a61, #005f40);
    border: 4px solid #aeffe4;
    border-radius: 8px;
    box-shadow:
      0 0.6rem 1rem rgb(0 0 0 / 0.18),
      0 0 0 1px rgb(174 255 228 / 0.18),
      inset 0 1px 0 rgb(255 255 255 / 0.3);
    transition:
      transform 55ms ease,
      box-shadow 55ms ease,
      background 55ms ease,
      border-color 55ms ease;
  }

  .socialLink:hover,
  .socialLink:focus-visible {
    transform: translateY(-3px) scale(1.03);
    box-shadow: 0 0.85rem 1.35rem rgb(0 0 0 / 0.22);
    background: linear-gradient(180deg, #17a06f, #0a6f4d);
    border-color: #d7fff2;
    outline: none;
  }

  .socialLink svg {
    flex: none;
    fill: currentColor;
    inline-size: 24px;
    block-size: 24px;
  }

  @media (max-width: 640px) {
    .stage {
      padding: 1.5rem 1rem 2rem;
    }

    .callout {
      padding: 2rem 1.3rem 1.8rem;
    }
  }
</style>
