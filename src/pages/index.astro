        <a class="year year--2026" href="/2026">
          <span class="year__label">2026</span>
          <span class="year__status">JUST HAPPENED</span>
        </a>
        <a class="year year--2025" href="/2025">
          <span class="year__label">2025</span>
          <span class="year__status">PHOTO ARCHIVE</span>
        </a>
      </nav>
      <div class="social" aria-label="Social links">
