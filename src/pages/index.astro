---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Game Sewer — Vancouver Indie Game Showcase"
  description="Game Sewer is Vancouver's indie game showcase. Browse photos and info from our 2026 and 2025 events."
  canonical="/"
  ogImage="/og-image.png"
>
  <main class="stage">
    <section class="callout">
      <p class="callout__brand">GAME SEWER</p>
      <p class="callout__sub">VANCOUVER'S INDIE GAME SHOWCASE</p>
