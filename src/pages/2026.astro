---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Game Sewer 2026">
  <main class="stage">
    <div class="container" aria-hidden="true">
      <div class="face face--front"></div>
      <div class="face face--back"></div>
      <div class="side side--start"></div>
      <div class="side side--end"></div>
      <div class="edge bottom"></div>
    </div>
    <section class="callout" aria-label="Art request">
      <p class="callout__intro">WE'RE SO BACK VANCOUVER</p>
      <p class="callout__eyebrow">2026 CALL FOR ART</p>
      <ul class="callout__list">
        <li>VIDEOGAMES</li>
        <li>COOL BOOTHS</li>
        <li>PERFORMANCE ART</li>
        <li>SOMETHING ELSE?</li>
      </ul>
      <p class="callout__contact">
        <span class="callout__new">*NEW*</span><br />
        <a href="https://forms.gle/GwoS193x6aFtkzvK6" target="_blank" rel="noopener noreferrer">SIGN UP HERE!</a>
      </p>
      <p class="callout__contact">
        HAVE ANY QUESTIONS?
        <a href="mailto:tip@gamesewer.com">TIP@GAMESEWER.COM</a>
      </p>
      <div class="social" aria-label="Social links">
