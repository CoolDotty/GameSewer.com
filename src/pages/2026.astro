      </div>
    </section>
  </main>
</BaseLayout>

<style>
  @font-face {
    font-family: 'Candy Beans';
    src: url('/Candy Beans.otf') format('opentype');
    font-weight: normal;
    font-style: normal;
  }

  :global(:root) {
    --duration: 7.25s;
  }

  .stage {
    min-block-size: 100vh;
    min-block-size: 100dvb;
    display: grid;
    place-items: center;
    align-content: center;
    gap: 2rem;
    padding: 2rem 1.5rem 3rem;
    overflow: hidden;
    background: linear-gradient(to bottom, #aeffe4, #005f40);
    perspective: 750px;
  }

  .stage :global(*),
  .stage :global(*::before),
  .stage :global(*::after) {
    box-sizing: border-box;
  }

  .container {
    position: relative;
    inline-size: 60vmin;
    max-inline-size: 100%;
    aspect-ratio: 400 / 355;
    transform-origin: center;
    transform-style: preserve-3d;
    animation: swing var(--duration) ease-in-out infinite alternate;
  }

  .callout {
    position: relative;
    inline-size: min(48rem, 100%);
    min-block-size: 24rem;
    padding: 2rem 2rem 1.75rem;
    color: #fff;
    font-family: 'Candy Beans';
    display: grid;
    align-content: center;
    text-align: center;
    text-transform: uppercase;
    background:
      linear-gradient(180deg, rgb(5 88 58 / 0.78), rgb(3 56 38 / 0.92)),
      radial-gradient(circle at top, rgb(174 255 228 / 0.24), transparent 55%);
    border: 4px solid rgb(174 255 228 / 0.72);
    border-radius: 1.5rem;
    box-shadow:
      0 1rem 2.5rem rgb(0 30 20 / 0.28),
      inset 0 1px 0 rgb(255 255 255 / 0.35);
    overflow: hidden;
  }

  .callout::before {
    content: '';
    position: absolute;
    inset: 0.55rem;
    border: 2px dashed rgb(255 255 255 / 0.28);
    border-radius: 1rem;
    pointer-events: none;
  }

  .callout > * {
    position: relative;
    z-index: 1;
  }

  .callout__intro {
    margin: 0 0 1rem;
    color: #83ff00;
    font-size: clamp(1.9rem, 3.6vw, 3.1rem);
    line-height: 0.95;
    letter-spacing: 0.04em;
    text-shadow:
      0 2px 0 rgb(0 72 38 / 0.82),
      0 0 0.45rem rgb(70 255 152 / 0.7),
      0 0 1rem rgb(70 255 152 / 0.45),
      0 0 1.8rem rgb(70 255 152 / 0.24);
  }

  .callout__eyebrow {
    display: inline-flex;
    justify-self: center;
    align-items: center;
    min-block-size: 4.25rem;
    margin-block-end: 0.85rem;
    padding: 0.55rem 1.45rem 0.4rem;
    color: #005f40;
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    line-height: 1;
    letter-spacing: 0.04em;
    background: #aeffe4;
    border-radius: 999px;
    border: 2px solid rgb(215 255 242 / 0.95);
    box-shadow:
      0 0.35rem 0.75rem rgb(0 0 0 / 0.18),
      0 0 1.1rem rgb(255 214 82 / 0.38),
      0 0 2.4rem rgb(255 214 82 / 0.2),
      inset 0 1px 0 rgb(255 255 255 / 0.65);
    text-shadow:
      0 1px 0 rgb(255 255 255 / 0.18),
      0 0 0.7rem rgb(255 223 124 / 0.55);
    transform-origin: center;
    animation: callout-shine 3.2s ease-in-out infinite;
  }

  .callout__heading {
    max-inline-size: 12ch;
    margin: 0 auto;
    font-size: clamp(2.1rem, 4vw, 3.6rem);
    line-height: 1.05;
    text-shadow:
      0 3px 0 rgb(0 95 64 / 0.9),
      0 0.45rem 1.25rem rgb(0 0 0 / 0.28);
  }

  .callout__list {
    display: grid;
    gap: 0.45rem;
    margin: 1.2rem 0 1.4rem;
    padding: 0;
    list-style: none;
    font-size: clamp(1.55rem, 2.4vw, 2.2rem);
    line-height: 1.05;
    text-shadow: 0 2px 0 rgb(0 95 64 / 0.78);
  }

  .callout__list li::before {
    content: '-';
    margin-inline-end: 0.2em;
  }

  .callout__contact {
    max-inline-size: 22ch;
    margin: 0 auto 1.5rem;
    font-size: clamp(1.35rem, 2.1vw, 1.95rem);
    line-height: 1.05;
    text-shadow: 0 2px 0 rgb(0 95 64 / 0.78);
  }

  .callout__new {
    display: inline-block;
    color: #fff;
    animation: callout-text-shine 3.2s ease-in-out infinite;
  }

  .callout__contact a {
    display: inline-block;
    margin-top: 0.45rem;
    max-inline-size: 100%;
    padding: 0.4rem 0.85rem 0.2rem;
    color: #fff;
    text-decoration: none;
    overflow-wrap: anywhere;
    background: rgb(0 95 64 / 0.45);
    border: 2px solid rgb(174 255 228 / 0.6);
    border-radius: 0.8rem;
    box-shadow:
      0 0.5rem 1rem rgb(0 0 0 / 0.18),
      inset 0 1px 0 rgb(255 255 255 / 0.25);
  }

  .social {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.8rem;
    margin-top: 1.2rem;
  }

  .socialLink {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: 4em;
    block-size: 4em;
    padding: 0;
    color: #fff;
    text-decoration: none;
    background: linear-gradient(180deg, #0f8a61, #005f40);
    border: 4px solid #aeffe4;
    border-radius: 8px;
    box-shadow:
      0 0.6rem 1rem rgb(0 0 0 / 0.18),
      0 0 0 1px rgb(174 255 228 / 0.18),
      inset 0 1px 0 rgb(255 255 255 / 0.3);
    transition:
      transform 55ms ease,
      box-shadow 55ms ease,
      background 55ms ease,
      border-color 55ms ease;
  }

  .socialLink:hover,
  .socialLink:focus-visible {
    transform: translateY(-3px) scale(1.03);
    box-shadow: 0 0.85rem 1.35rem rgb(0 0 0 / 0.22);
    background: linear-gradient(180deg, #17a06f, #0a6f4d);
    border-color: #d7fff2;
    outline: none;
  }

  .socialLink svg {
    flex: none;
    fill: currentColor;
    inline-size: 24px;
    block-size: 24px;
  }

  @keyframes swing {
    from {
      transform: rotateX(18deg) rotateY(-45deg);
    }

    to {
      transform: rotateX(-18deg) rotateY(45deg);
    }
  }

  @keyframes callout-shine {
    0%,
    100% {
      color: #376122;
      transform: scale(1);
      box-shadow:
        0 0.35rem 0.75rem rgb(0 0 0 / 0.18),
        0 0 1.1rem rgb(255 214 82 / 0.38),
        0 0 2.4rem rgb(255 214 82 / 0.2),
        inset 0 1px 0 rgb(255 255 255 / 0.65);
      text-shadow:
        0 1px 0 rgb(255 255 255 / 0.18),
        0 0 0.7rem rgb(255 223 124 / 0.55);
    }

    45%,
    55% {
      color: #58701f;
      transform: scale(1.06);
      box-shadow:
        0 0.35rem 0.75rem rgb(0 0 0 / 0.18),
        0 0 1.35rem rgb(255 214 82 / 0.48),
        0 0 2.8rem rgb(255 214 82 / 0.26),
        inset 0 1px 0 rgb(255 255 255 / 0.72);
      text-shadow:
        0 1px 0 rgb(255 255 255 / 0.18),
        0 0 0.95rem rgb(255 223 124 / 0.68);
    }
  }

  @keyframes callout-text-shine {
    0%,
    100% {
      transform: scale(1);
      text-shadow:
        0 1px 0 rgb(255 255 255 / 0.18),
        0 0 0.7rem rgb(255 223 124 / 0.55);
    }

    45%,
    55% {
      transform: scale(1.06);
      text-shadow:
        0 1px 0 rgb(255 255 255 / 0.18),
        0 0 0.95rem rgb(255 223 124 / 0.68);
    }
  }

  .container > * {
    position: absolute;
    background-size: 100%;
  }

  .face::after,
  .side::after {
    content: '';
    position: absolute;
    inset-inline: 0;
    inset-block: 0;
    display: block;
    opacity: 0;
    pointer-events: none;
  }

  .side::before {
    content: '';
    position: absolute;
    inset-inline: 0;
    inset-block: 0;
    display: block;
    opacity: 1;
    pointer-events: none;
  }

  .face {
    inline-size: 100%;
    block-size: 100%;
    background-color: transparent;
  }

  .face--front,
  .face--back {
    background-image: url('./2026/cover.png');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .face--front {
    transform: translateZ(calc(2.5vmin - 1px));
  }

  .face--back {
    transform: translateZ(calc(-2.5vmin + 1px)) rotateY(180deg);
  }

  .face--back::after {
    opacity: 0.5;
  }

  .side {
    inline-size: 5vmin;
    block-size: 100%;
  }

  .side--start {
    transform: rotateY(-90deg) translateZ(2.5vmin);
  }

  .side--start::before {
    background-image: url('./2026/side.png');
    background-position: center;
    background-repeat: no-repeat;
    background-size: contain;
    animation: fade-front var(--duration) ease-in-out infinite alternate;
  }

  .side--start::after {
    animation: fade-front var(--duration) ease-in-out infinite alternate;
  }

  .side--end {
    inset-inline-end: 0;
    transform: rotateY(90deg) translateZ(2.5vmin);
  }

  .side--end::before {
    background-image: url('./2026/open.png');
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
    animation: fade-side-start var(--duration) ease-in-out infinite alternate;
  }

  .side--end::after {
    animation: fade-front var(--duration) ease-in-out infinite alternate;
  }

  .face--front::after {
    animation: fade-front var(--duration) ease-in-out infinite alternate;
  }
/* 
  @keyframes fade-front {
    0%,
    12%,
    88%,
    100% {
      opacity: 0.25;
    }

    42%,
    58% {
      opacity: 0;
    }
  } */

  .bottom {
    inline-size: 100%;
    block-size: 5vmin;
    inset-block-end: 0;
    background-color: darkgrey;
    transform: rotateX(90deg) translateZ(calc(-2.5vmin + 1px));
  }

  @media (max-width: 640px) {
    .stage {
      gap: 1.5rem;
      padding-inline: 1rem;
      padding-block: 1.5rem 2rem;
    }

    .container {
      inline-size: min(80vmin, 22rem);
    }

    .callout {
      min-block-size: 20rem;
      padding: 1.4rem 1.1rem 1.2rem;
    }

    .callout__eyebrow {
      min-block-size: 3.65rem;
      padding-inline: 1rem;
    }
  }
 </style>
